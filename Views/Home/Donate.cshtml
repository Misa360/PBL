@{
    ViewData["Title"] = "Đóng góp & Ủng hộ";
}

<style>
/* ═══════════════════════════════════════════
   DONATE PAGE — VCF-inspired Premium
   ═══════════════════════════════════════════ */

/* ── Scroll reveal animation ── */
.dn-reveal {
    opacity: 0;
    transform: translateY(50px);
    transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
}
.dn-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
}
.dn-reveal.delay-1 { transition-delay: 0.18s; }
.dn-reveal.delay-2 { transition-delay: 0.36s; }
.dn-reveal.delay-3 { transition-delay: 0.54s; }

/* Slide from left */
.dn-reveal-left {
    opacity: 0;
    transform: translateX(-60px);
    transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
}
.dn-reveal-left.is-visible {
    opacity: 1;
    transform: translateX(0);
}

/* Slide from right */
.dn-reveal-right {
    opacity: 0;
    transform: translateX(60px);
    transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
}
.dn-reveal-right.is-visible {
    opacity: 1;
    transform: translateX(0);
}

/* Scale in */
.dn-reveal-scale {
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.8s ease, transform 0.8s ease;
}
.dn-reveal-scale.is-visible {
    opacity: 1;
    transform: scale(1);
}

/* ── Section 1: Hero split ── */
.dn-hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 620px;
}

.dn-hero-left {
    position: relative;
    color: #fff;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 60px;
    overflow: hidden;
}

.dn-hero-left-bg {
    position: absolute;
    inset: 0;
    background: url('https://images.unsplash.com/photo-1559592413-7cec4d0cae2b?w=1200&q=80') center/cover no-repeat;
    z-index: 0;
}

.dn-hero-left-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0, 105, 92, 0.88) 0%, rgba(0, 137, 123, 0.8) 50%, rgba(38, 166, 154, 0.75) 100%);
    z-index: 1;
}

.dn-hero-left > *:not(.dn-hero-left-bg):not(.dn-hero-left-overlay) {
    position: relative;
    z-index: 2;
}

.dn-hero-tag {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #b2dfdb;
    margin-bottom: 24px;
}

.dn-hero-title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 800;
    line-height: 1.25;
    margin-bottom: 28px;
    letter-spacing: -0.5px;
}

.dn-hero-desc {
    font-size: 16px;
    line-height: 1.8;
    opacity: 0.88;
    max-width: 480px;
}

.dn-hero-right {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f0;
    padding: 50px;
}

.dn-qr-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.08);
    padding: 40px;
    max-width: 420px;
    width: 100%;
    text-align: center;
    position: relative;
    z-index: 2;
}

.dn-qr-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 5px;
    background: linear-gradient(90deg, #00897b, #26a69a, #4db6ac);
    border-radius: 16px 16px 0 0;
}

.dn-qr-card h3 {
    font-family: 'Montserrat', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: #222;
    margin-bottom: 8px;
}

.dn-qr-subtitle {
    font-size: 14px;
    color: #888;
    margin-bottom: 25px;
    line-height: 1.5;
}

.dn-qr-frame {
    background: #fafafa;
    border: 2px dashed #e0e0e0;
    border-radius: 12px;
    padding: 15px;
    display: inline-block;
    transition: border-color 0.3s, box-shadow 0.3s;
}

.dn-qr-frame:hover {
    border-color: #00897b;
    box-shadow: 0 8px 25px rgba(0, 137, 123, 0.12);
}

.dn-qr-frame img {
    width: 240px;
    height: auto;
    border-radius: 8px;
    display: block;
}

.dn-qr-secure {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 22px;
    font-size: 12.5px;
    color: #999;
}

.dn-qr-secure svg {
    width: 14px;
    height: 14px;
    stroke: #4caf50;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
}

/* ── Section 2: Cách thức (centered) ── */
.dn-how-section {
    background: #fff;
    padding: 100px 24px;
    text-align: center;
}

.dn-how-tag {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #00897b;
    margin-bottom: 20px;
}

.dn-how-title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(26px, 3vw, 38px);
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 30px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.35;
}

.dn-how-text {
    font-size: 16px;
    line-height: 1.9;
    color: #666;
    max-width: 800px;
    margin: 0 auto;
}

/* ── Section 3: Steps (alternating) ── */
.dn-step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 400px;
    align-items: center;
}

.dn-step-bg-light {
    background: #f9f7f2;
}

.dn-step-bg-white {
    background: #fff;
}

.dn-step-img-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 50px;
}

.dn-step-img-wrap img {
    width: 85%;
    max-width: 440px;
    height: 300px;
    object-fit: cover;
    border-radius: 16px;
    box-shadow: 0 12px 35px rgba(0,0,0,0.1);
    display: block;
}

.dn-step-content {
    padding: 60px 70px;
}

.dn-step-label {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #c0392b;
    margin-bottom: 18px;
}

.dn-step-title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(20px, 2.2vw, 28px);
    font-weight: 700;
    color: #1a1a2e;
    line-height: 1.45;
}

/* ── Section 4: Methods (cards) ── */
.dn-methods-section {
    background: #f5f5f0;
    padding: 100px 24px;
}

.dn-methods-inner {
    max-width: 1100px;
    margin: 0 auto;
}

.dn-methods-head {
    text-align: center;
    margin-bottom: 60px;
}

.dn-methods-head .dn-how-tag {
    margin-bottom: 15px;
}

.dn-methods-head h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(24px, 2.5vw, 34px);
    font-weight: 700;
    color: #1a1a2e;
}

.dn-method-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
}

.dn-method-card {
    background: #fff;
    border-radius: 14px;
    padding: 40px 30px;
    text-align: center;
    box-shadow: 0 8px 30px rgba(0,0,0,0.04);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    position: relative;
    overflow: hidden;
}

.dn-method-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #00897b, #26a69a);
    transform: scaleX(0);
    transition: transform 0.4s ease;
}

.dn-method-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 45px rgba(0,0,0,0.08);
}

.dn-method-card:hover::after {
    transform: scaleX(1);
}

.dn-method-icon {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, #e0f2f1, #b2dfdb);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
}

.dn-method-icon svg {
    width: 28px;
    height: 28px;
    stroke: #00695c;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
}

.dn-method-card h4 {
    font-size: 18px;
    font-weight: 700;
    color: #222;
    margin-bottom: 12px;
}

.dn-method-card p {
    font-size: 14px;
    line-height: 1.7;
    color: #777;
}

/* ── Section 5: CTA ── */
.dn-cta {
    position: relative;
    padding: 80px 24px;
    text-align: center;
    color: #fff;
    overflow: hidden;
}

.dn-cta-bg {
    position: absolute;
    inset: 0;
    background: url('https://images.unsplash.com/photo-1583417319070-4a69db38a482?w=1920&q=80') center/cover no-repeat;
}

.dn-cta-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 105, 92, 0.88);
}

.dn-cta > *:not(.dn-cta-bg):not(.dn-cta-overlay) {
    position: relative;
    z-index: 2;
}

.dn-cta h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    margin-bottom: 18px;
}

.dn-cta p {
    font-size: 16px;
    opacity: 0.85;
    max-width: 550px;
    margin: 0 auto 35px;
    line-height: 1.7;
}

.dn-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    color: #00695c;
    padding: 14px 36px;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.3s, box-shadow 0.3s;
    box-shadow: 0 6px 20px rgba(0,0,0,0.12);
}

.dn-cta-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.18);
}

.dn-cta-btn svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
}

/* ── Responsive ── */
@@media (max-width: 960px) {
    .dn-hero-split {
        grid-template-columns: 1fr;
    }
    .dn-hero-left {
        padding: 60px 30px;
    }
    .dn-hero-right {
        padding: 40px 30px;
    }
    .dn-step {
        grid-template-columns: 1fr;
    }
    .dn-step-img-wrap {
        padding: 30px;
    }
    .dn-step-img-wrap img {
        width: 100%;
        height: 240px;
    }
    .dn-step-content {
        padding: 40px 30px;
    }
    .dn-method-grid {
        grid-template-columns: 1fr;
        max-width: 420px;
        margin: 0 auto;
    }
}
</style>

<div class="dsm-page hr-light-theme">

    <!-- ═══════════ SECTION 1: Hero Split ═══════════ -->
    <section class="dn-hero-split">
        <div class="dn-hero-left">
            <div class="dn-hero-left-bg"></div>
            <div class="dn-hero-left-overlay"></div>
