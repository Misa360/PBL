        </div>
    </div>

    <!-- Bước 2 -->
    <div class="dn-step dn-step-bg-white">
        <div class="dn-step-img-wrap">
            <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&q=80" alt="Phát triển hệ thống" class="dn-reveal-left" />
        </div>
        <div class="dn-step-content">
            <div class="dn-step-label dn-reveal-right">Bước 2</div>
